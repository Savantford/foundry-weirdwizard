{{!-- Name Stripe --}}
<header class="name-stripe">

    {{!-- Item Name --}}
    <h1 class="charname"><input name="name" type="text" value="{{item.name}}" placeholder="{{localize "WW.Item.Name"}}" /></h1>

    <img class="profile-img" src="{{item.img}}" data-action="editImage" data-edit="img" data-tooltip="WW.System.EditImage"/>

</header>
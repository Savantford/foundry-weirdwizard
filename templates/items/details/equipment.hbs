<div class="fields stat-inline flex-wrap flex-children">
  
  {{!-- Classification Row --}}
  <div class="common-fields flex-children">
    {{!-- Subtype --}}
    <select name="system.subtype">
      {{selectOptions subtypes selected=system.subtype localize=true}}
    </select>

    {{!-- Armor Type --}}
    {{#if (eq system.subtype 'armor')}}
    <label>{{localize "WW.Equipment.Category"}}:</label>

    <select name="system.armorType">
        {{selectOptions armorTypes selected=system.armorType localize=true}}
    </select>
    {{/if}}

    {{!-- Weapon Info --}}
    {{#if (eq system.subtype 'weapon')}}
    <label>{{localize "WW.Equipment.Category"}}:</label>

    {{!-- Grip --}}
    <div>
      <select name="system.grip" data-tooltip="WW.Weapon.Grip.Label">
        {{selectOptions grips selected=system.grip localize=true}}
      </select>
    </div>
    {{/if}}

    {{!-- Container Capacity --}}
    {{#if (eq system.subtype 'container')}}
    <div class="capacity">
      <label>{{localize "WW.Container.Capacity"}}:</label>
    
      <div class="input-wrap">
        <input type="number" name="system.capacity" value="{{system.capacity}}" min="1" data-dtype="Number"
          data-tooltip="WW.Container.CapacityHint" />
    
        <div class="input-overlay">{{system.capacity}}</div>
      </div>
    
    </div>
    {{/if}}
    
    {{!-- Quality --}}
    <div>
      <label>{{localize "WW.Equipment.Quality.Label"}}:</label>
      <select name="system.quality">
        {{selectOptions qualities selected=system.quality localize=true}}
      </select>
    </div>

    {{!-- Magical --}}
    <div>
      <label>{{localize "WW.Talent.Magical"}}:</label>
    
      <input type="checkbox" class="checkbox-uses" name="system.magical" data-tooltip="WW.Talent.MagicalHint" {{checked system.magical}} />
    </div>

  </div>

  {{!-- Common Fields --}}
  {{#unless (and (eq system.subtype 'weapon') (eq system.grip 'natural'))}}
  <div class="common-fields flex-children">
    {{!-- Availability --}}
    <div>
      <label>{{localize "WW.Equipment.Availability.Label"}}:</label>
      <select name="system.availability">
        {{selectOptions availabilities selected=system.availability localize=true}}
      </select>
    </div>

    {{!-- Price --}}
    <div>
      <label>{{localize "WW.Equipment.Price"}}:</label>

      <div class="input-wrap">
        <input type="number" name="system.price.value" value="{{system.price.value}}" min="0" data-dtype="Number" />

        <div class="input-overlay">{{system.price.value}}</div>
      </div>

      <select name="system.price.coin">
        {{selectOptions coins selected=system.price.coin localize=true}}
      </select>
    </div>
    
    {{!-- Requirements --}}
    {{#if (or (eq system.subtype "weapon") (eq system.subtype "armor"))}}
    <div>
      <label>{{localize "WW.Equipment.Requirement.Label"}}:</label>

      <select name="system.requirements">
        {{selectOptions requirements selected=system.requirements localize=true}}
      </select>
    </div>
    {{/if}}

  </div>
  {{/unless}}
  
  <hr>

  {{!-- Usage Row --}}
  <div class="common-fields flex-children">
    {{!-- Uses --}}
    <div>
      <label>{{localize "WW.Equipment.Uses"}}:</label>
  
      <div class="input-wrap">
        <input type="number" name="system.uses.max" value="{{system.uses.max}}" min="0" data-dtype="Number" />
  
        <div class="input-overlay">{{system.uses.max}}</div>
      </div>
  
      <input class="checkbox-uses" type="checkbox" name="system.uses.onRest" {{checked system.uses.onRest}}
        data-tooltip="WW.Item.Uses.OnRest" />
    </div>

    {{!-- Quantity --}}
    <div class="stat-inline">
      <label>{{localize "WW.Equipment.Quantity"}}:</label>
  
      <div class="input-wrap">
        <input type="number" name="system.quantity" value="{{system.quantity}}" min="0" data-dtype="Number" />
  
        <div class="input-overlay">{{system.quantity}}</div>
      </div>
  
    </div>

    {{!-- Weight --}}
    <div class="stat-inline">
      <label>{{localize "WW.Equipment.WeightUnit"}}:</label>
  
      <div class="input-wrap">
        <input type="number" name="system.weightUnit" value="{{system.weightUnit}}" min="0" data-dtype="Number" />
  
        <div class="input-overlay">{{system.weightUnit}}</div>
      </div>
    </div>
  </div>
  
  {{!-- Weapon Fields --}}
  {{#if (eq system.subtype 'weapon')}}
  <h5 class="mb-0">{{localize "WW.Weapon.Details"}}</h5>

  <div class="weapon-fields">
    {{!-- Range and Damage Row --}}
    <div class="stat-inline flex-wrap flex-children">

      {{!-- Range --}}
      {{#if hasRange}}
      <div>
        <label>{{localize "WW.Weapon.Traits.Range.Label"}} / {{localize "WW.Weapon.Traits.Thrown.Label"}}:</label>
    
        <div class="input-wrap">
          <input type="number" name="system.range" value="{{system.range}}" min="0" placeholder="0" data-dtype="Number" />
    
          <div class="input-overlay">{{system.range}}</div>
        </div>
      </div>
      {{/if}}
  
      {{!-- Damage --}}
      <div>
        <label>{{localize "WW.Damage.Label"}}:</label>
  
        <input type="text" name="system.damage" value="{{system.damage}}" placeholder="1d6"
          style="width: 50px; text-align: left;" data-dtype="String" />
  
        {{!-- Alternative Text --}}
        <input type="text" name="system.damageAlt" value="{{system.damageAlt}}" placeholder="{{localize "WW.Item.Alt"}}"
          data-tooltip-text="{{localize "WW.Item.AltTip"}}" data-dtype="String" />
      </div>
  
    </div>
  
    {{!-- Weapon Traits --}}
    <div class="weapon-traits">
    {{#with traits}}
      {{formInput field type="checkboxes" class="weapon-traits" options=options name=name value=value localize=true sort=true }}
    {{/with}}
    </div>
    
    {{!-- Attack Rider --}}
    <div class="attack-rider">
      <h3>{{localize "WW.Attack.Rider"}}</h3>

      <input class="mb-1" type="text" name="system.attackRider.name" value="{{system.attackRider.name}}">
      
      {{!-- Attack Rider Text Editor --}}
      <prose-mirror name="system.attackRider.value" data-document-u-u-i-d="{{item.uuid}}"
        value="{{system.attackRider.value}}" toggled collaborate compact editable={{editable}}>
        {{{system.attackRiderEnriched}}}
      </prose-mirror>
    </div>
  
  </div>
  {{/if}}

</div>
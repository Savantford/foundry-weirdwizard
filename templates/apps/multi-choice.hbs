<div class="{{purpose}}">
    {{!-- Sections --}}
    <div class="mc-sections">
        
        {{#each sections as |section|}}
        <div class="mc-section {{#if collapsed}}collapsed{{/if}}">
            
            {{!-- Section Title --}}
            {{#if title}}
            <h3>
                {{#if img}}<i class="fa-solid fa-{{{img}}}"></i> {{/if}}
                {{localize title}}
                {{#unless noCollapse}}
                <i class="fa-solid {{#if collapsed}}fa-circle-chevron-up{{else}}fa-circle-chevron-down{{/if}}" data-action="collapseSection"></i>
                {{/unless}}
            </h3>
            {{/if}}
            
            {{!-- Choices Grid --}}
            <div class="section-content">
                <div class="choices-grid" style="--cols: {{cols}};">
                    {{#each choices as |choice|}}
                    <label data-tooltip="{{tip}}">
                        <input type="checkbox" name="{{#if uuid}}{{uuid}}{{else if id}}{{id}}{{else}}{{path}}{{/if}}" {{checked value}}>
                        {{#if img}}<img src={{img}}> {{/if}}{{localize label}}
                    </label>
                    {{/each}}
                </div>

            </div>

        </div>
        {{/each}}

    </div>{{!-- END Sections --}}
    
    {{!-- Clear Afflictions Button --}}
    {{#if clearAfflictionsLabel}}
    <div class="mc-buttons">
        <button data-action="clearAfflictions">{{clearAfflictionsLabel}}</button>
    </div>
    {{/if}}

    {{!-- Spear Divider --}}
    <div class="spear-divider"></div>

    {{!-- Form Buttons ---}}
    <div class="mc-buttons">
        <button>{{submitLabel}}</button>

        <button value="cancel">{{localize "WW.System.Dialog.Cancel"}}</button>
    </div>

</div>

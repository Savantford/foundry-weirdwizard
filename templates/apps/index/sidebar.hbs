<section class="sidebar">
  <div class="sidebar-content">
    <div class="sidebar-header">
      {{!-- View Selection --}}
      <div class="flexrow">
        <label>{{localize "WW.System.Index.ViewAs"}}</label>
      
        <select data-action="changeView">
          {{selectOptions views selected=view localize=true}}
        </select>
      </div>

      {{!-- Search --}}
      <input type="text" class="search" placeholder="{{localize "WW.System.Index.Search"}}">

      <hr class="spear">
    </div>
    
    {{!-- Filters --}}
    <div class="filters">

      {{!-- Source Compendia --}}
      {{#with filters.source}}
      <details class="filter">
        <summary>{{label}}</summary>

        {{formInput field type="checkboxes" name="source" options=options value="world.adsasf"}}
        
      </details>
      {{/with}}

      {{!-- Source Compendia --}}
      {{#with filters.source}}
      <details class="filter">
        <summary>{{label}}</summary>

        {{formInput field type="checkboxes" name="source" options=options value="world.adsasf"}}
        
      </details>
      {{/with}}


    </div>
  </div>
  
</section>
<section class="view spells">

    {{!-- Header Row --}}
    <li class="item flexrow items-header">
        <div class="item-image"></div>
        <div class="item-name">{{localize "WW.Item.Name"}}</div>

        <div class="flex-width-60">{{localize "WW.Item.Tier"}}</div>
        <div class="flex-width-60">{{localize "WW.Spell.Tradition"}}</div>
        <div>{{localize "WW.Spell.Castings"}}</div>
        <div>{{localize "WW.Spell.Target"}}</div>
        <div>{{localize "WW.Spell.Duration"}}</div>
        <div class="item-last">{{localize "WW.Item.Description"}}</div>
    </li>

    {{!-- Rows --}}
    <ol class="item-list">
        {{#each documents as |doc id|}}
        <li class="item flexrow flex-group-left" data-item-id="{{doc._id}}">
            {{!-- Icon --}}
            <div class="item-image"><img src="{{doc.img}}" data-tooltip="{{doc.name}}" width="24" height="24" /></div>

            {{!-- Name --}}
            <div class="item-name">
                <a data-action="openSheet" data-item-uuid="{{doc.uuid}}" data-tooltip="{{doc.tooltip}}">{{doc.name}}</a>
            </div>

            <div class="flex-width-60">{{doc.tierLabel}}</div>
            <div class="flex-width-60">{{doc.system.tradition}}</div>
            <div>{{doc.system.uses.max}}{{#if doc.system.casting}}, {{doc.system.casting}}{{/if}}</div>
            <div>{{doc.system.target}}</div>
            <div>{{doc.system.duration}}</div>
            <div class="item-last">{{{doc.system.descriptionEnriched}}}</div>

        </li>
        {{/each}}
    </ol>

</section>

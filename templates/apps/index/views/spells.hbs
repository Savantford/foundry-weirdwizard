<section class="view spells">
    {{!-- Header Row --}}
    <li class="item flexrow items-header">
        <div class="item-image"></div>
    
        {{#each colHeaders as |header id|}}
            {{> "systems/weirdwizard/templates/apps/index/parts/col-header.hbs" data=header }}
        {{/each}}
    </li>

    {{!-- Rows --}}
    <ol class="item-list">
        {{#each documents as |doc id|}}
        <li class="item flexrow flex-group-left" data-doc-uuid="{{uuid}}">
            {{!-- Icon --}}
            <div class="item-image"><img src="{{img}}" data-tooltip="{{name}}" width="24" height="24" /></div>

            {{!-- Name --}}
            <div class="item-name">
                <a data-action="openSheet" data-doc-uuid="{{uuid}}" data-tooltip="{{tooltip}}">{{name}}</a>
            </div>

            <div class="flex-width-60">{{tierLabel}}</div>
            <div class="flex-width-60">{{system.tradition}}</div>
            <div>{{system.uses.max}}{{#if doc.system.casting}}, {{system.casting}}{{/if}}</div>
            <div>{{system.target}}</div>
            <div>{{system.duration}}</div>
            <div class="item-last">{{{system.descriptionEnriched}}}</div>

        </li>
        {{/each}}
    </ol>

</section>

<section class="view talents">
    {{!-- Header Row --}}
    <li class="item flexrow items-header">
        <div class="item-image"></div>
        <div class="item-name">{{localize "WW.Item.Name"}}</div>

        <div class="flex-width-60">{{localize "WW.Item.Type"}}</div>
        <div class="flex-width-50">{{localize "WW.Talent.Magical"}}</div>
        <div>{{localize "WW.Talent.Uses"}}</div>
        <div>{{localize "WW.Item.UsedBy"}}</div>
        <div class="item-last">{{localize "WW.Item.Description"}}</div>
    </li>

    {{!-- Rows --}}
    <ol class="item-list">
        {{#each documents as |doc id|}}
        <li class="item flexrow flex-group-left" data-item-id="{{doc._id}}">
            {{!-- Icon --}}
            <div class="item-image"><img src="{{doc.img}}" data-tooltip="{{doc.name}}" width="24" height="24" /></div>

            {{!-- Name --}}
            <div class="item-name">
                <a data-action="openSheet" data-item-uuid="{{doc.uuid}}" data-tooltip="{{doc.tooltip}}">{{doc.name}}</a>
            </div>

            <div class="flex-width-60">{{doc.talentTypeLabel}}</div>
            <div class="flex-width-50"><i class="fa-solid {{#if doc.system.magical}}fa-check{{else}}fa-xmark-large{{/if}}"></i></div>
            <div>{{#if (eq doc.system.uses.max 0)}}<span style="font-size: large">∞</span>{{else}}{{doc.system.uses.max}}{{/if}}</div>
            <div>{{{ doc.usedByLinks }}}</div>
            <div class="item-last">{{{doc.system.descriptionEnriched}}}</div>

        </li>
        {{/each}}
    </ol>

</section>
<section class="view creatures">
    {{!-- Header Row --}}
    <li class="item flexrow items-header">
        <div class="item-image"></div>
    
        {{#each colHeaders as |header id|}}
            {{> "systems/weirdwizard/templates/apps/index/parts/col-header.hbs" data=header }}
        {{/each}}
    </li>

    {{!-- Rows --}}
    <ol class="item-list">
        {{#each documents as |doc id|}}
        <li class="item flexrow flex-group-left" data-doc-uuid="{{uuid}}">
            {{!-- Icon --}}
            <div class="item-image"><img src="{{img}}" data-tooltip="{{name}}" width="24" height="24" /></div>

            {{!-- Name --}}
            <div class="item-name">
                <a data-action="openSheet" data-doc-uuid="{{uuid}}" data-tooltip="{{tooltip}}">{{name}}</a>
            </div>
            
            <div class="flex-width-60">{{ creatureGroup }}</div>
            <div class="flex-width-70">{{ creatureDifficulty }}</div>
            <div>{{{ creatureDescriptors }}}</div>

            <div class="flex-width-70">{{ creatureStrength }}</div>
            <div class="flex-width-60">{{ creatureAgility }}</div>
            <div class="flex-width-70">{{ creatureIntellect }}</div>
            <div class="flex-width-50">{{ creatureWill }}</div>
            
            <div class="flex-width-60">{{ creatureDefense }}</div>
            <div class="flex-width-60">{{ creatureHealth }}</div>
            <div class="flex-width-50">{{ creatureSize }}</div>
            <div class="flex-width-50">{{ creatureSpeed }}</div>
        </li>
        {{/each}}
    </ol>

</section>
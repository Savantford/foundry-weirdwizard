<section class="view armor">

    {{!-- Header Row --}}
    <li class="item flexrow items-header">
        <div class="item-image"></div>
    
        {{#each colHeaders as |header id|}}
            {{> "systems/weirdwizard/templates/apps/index/parts/col-header.hbs" data=header }}
        {{/each}}
    </li>
    
    {{!-- Rows --}}
    <ol class="item-list armor-list">
        {{#each documents as |doc id|}}
        <li class="item flexrow flex-group-left" data-item-id="{{doc._id}}">
            {{!-- Icon --}}
            <div class="item-image"><img src="{{doc.img}}" data-tooltip="{{doc.name}}" width="24" height="24" /></div>

            {{!-- Name --}}
            <div class="item-name">
                <a data-action="openSheet" data-item-uuid="{{doc.uuid}}" data-tooltip="{{doc.tooltip}}">{{doc.name}}</a>
            </div>

            <div class="flex-width-60">{{ doc.armorTypeLabel }}</div>
            <div class="flex-width-60">{{ doc.defenseLabel }}</div>
            <div class="flex-width-80">{{ doc.availabilityLabel }}</div>
            <div class="flex-width-60">{{{ doc.priceLabel }}}</div>

            {{!-- Description --}}
            <div class="item-last">{{{ doc.system.descriptionEnriched }}}</div>
        </li>
        {{/each}}
    </ol>

</section>
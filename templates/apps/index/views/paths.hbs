<section class="view paths">

    {{!-- Header Row --}}
    <li class="item flexrow items-header">
        <div class="item-image"></div>
        <div class="item-name">{{localize "WW.Item.Name"}}</div>

        <div class="item-fixed">{{localize "WW.Item.Tier"}}</div>

        <div class="item-summary">{{localize "WW.Defense.Natural"}}</div>
        <div class="item-summary">{{localize "WW.Defense.Armored"}}</div>
        <div class="item-summary">{{localize "WW.Health.Label"}}</div>
        <div class="item-summary">{{localize "WW.Damage.Bonus"}}</div>
        <div class="item-summary">{{localize "WW.Stats.Speed"}}</div>

        <div class="item-last">{{localize "WW.CharOptions.PathTalents"}}</div>
    </li>

    {{!-- Rows --}}
    <ol class="item-list">
        {{#each documents as |doc id|}}
        <li class="item flexrow flex-group-left" data-item-id="{{doc._id}}">
            {{!-- Icon --}}
            <div class="item-image"><img src="{{doc.img}}" data-tooltip="{{doc.name}}" width="24" height="24" /></div>

            {{!-- Name --}}
            <div class="item-name">
                <a data-action="openSheet" data-item-uuid="{{doc.uuid}}" data-tooltip="{{doc.tooltip}}">{{doc.name}}</a>
            </div>

            <div class="item-fixed">{{ doc.tierLabel }}</div>

            {{!-- Stats Summary --}}
            <div class="item-summary">{{{ doc.benefitsSummary.natural }}}</div>
            <div class="item-summary">{{{ doc.benefitsSummary.armored }}}</div>
            <div class="item-summary">{{{ doc.benefitsSummary.health }}}</div>
            <div class="item-summary">{{{ doc.benefitsSummary.bonusDamage }}}</div>
            <div class="item-summary">{{{ doc.benefitsSummary.speed }}}</div>
            <div class="item-last">{{{ doc.benefitsSummary.talents }}}</div>
        </li>
        {{/each}}
    </ol>

</section>
<section class="view paths">
    {{!-- Header Row --}}
    <li class="item flexrow items-header">
        <div class="item-image"></div>
    
        {{#each colHeaders as |header id|}}
            {{> "systems/weirdwizard/templates/apps/index/parts/col-header.hbs" data=header }}
        {{/each}}
    </li>

    {{!-- Rows --}}
    <ol class="item-list">
        {{#each documents as |doc id|}}
        <li class="item flexrow flex-group-left" data-doc-uuid="{{uuid}}">
            {{!-- Icon --}}
            <div class="item-image"><img src="{{img}}" data-tooltip="{{name}}" width="24" height="24" /></div>

            {{!-- Name --}}
            <div class="item-name">
                <a data-action="openSheet" data-doc-uuid="{{uuid}}" data-tooltip="{{tooltip}}">{{name}}</a>
            </div>

            <div class="flex-width-60">{{ tierLabel }}</div>

            {{!-- Stats Summary --}}
            <div class="flex-width-60">{{{ benefitsSummary.natural }}}</div>
            <div class="flex-width-60">{{{ benefitsSummary.armored }}}</div>
            <div class="flex-width-60">{{{ benefitsSummary.health }}}</div>
            <div class="flex-width-60">{{{ benefitsSummary.bonusDamage }}}</div>
            <div class="flex-width-60">{{{ benefitsSummary.speed }}}</div>

            <div class="item-width-60">{{{ benefitsSummary.traditions }}}</div>
            <div class="item-width-60">{{{ benefitsSummary.spells }}}</div>
            
            <div class="item-last">{{{ benefitsSummary.talents }}}</div>
        </li>
        {{/each}}
    </ol>

</section>
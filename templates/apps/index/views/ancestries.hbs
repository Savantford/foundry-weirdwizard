<section class="view ancestries">
    {{!-- Header Row --}}
    <li class="item flexrow items-header">
        <div class="item-image"></div>
    
        {{#each colHeaders as |header id|}}
            {{> "systems/weirdwizard/templates/apps/index/parts/col-header.hbs" data=header }}
        {{/each}}
    </li>

    {{!-- Rows --}}
    <ol class="item-list">
        {{#each documents as |doc id|}}
        <li class="item flexrow flex-group-left" data-doc-uuid="{{uuid}}">
            {{!-- Icon --}}
            <div class="item-image"><img src="{{img}}" data-tooltip="{{name}}" width="24" height="24" /></div>

            {{!-- Name --}}
            <div class="item-name">
                <a data-action="openSheet" data-doc-uuid="{{uuid}}" data-tooltip="{{tooltip}}">{{name}}</a>
            </div>

            {{!-- Descriptors --}}
            <div>{{{ ancestryDescriptors }}}</div>

            {{!-- Senses --}}
            <div>{{{ ancestrySenses }}}</div>

            {{!-- Languages --}}
            <div>{{{ ancestryLanguages }}}</div>

            {{!-- Stats --}}
            <div class="flex-width-70">{{{ ancestryStats }}}</div>
            <div class="flex-width-50">{{ ancestrySize }}</div>
            <div>{{{ ancestrySpeed }}}</div>

            {{!-- Immunities --}}
            <div>{{{ ancestryImmunities }}}</div>

            {{!-- Traits --}}
            <div class="item-last">{{{ ancestryTraits }}}</div>

        </li>
        {{/each}}
    </ol>

</section>
<section class="view equipment">

    {{!-- Header Row --}}
    <li class="item flexrow items-header">
        <div class="item-image"></div>
        <div class="item-name">{{localize "WW.Item.Name"}}</div>
    
        <div>{{localize "WW.Equipment.Availability.Label"}}</div>
        <div>{{localize "WW.Equipment.Price"}}</div>
    </li>

    {{!-- Rows --}}
    <ol class="item-list equipment-list">
        {{#each documents as |doc id|}}
        <li class="item flexrow flex-group-left" data-item-id="{{doc._id}}">
            {{!-- Icon --}}
            <div class="item-image"><img src="{{doc.img}}" data-tooltip="{{doc.name}}" width="24" height="24" /></div>

            {{!-- Name --}}
            <a class="item-name" data-action="openSheet" data-item-uuid="{{doc.uuid}}" data-tooltip="{{{doc.tooltip}}}">{{doc.name}}</a>

            <div>{{doc.availabilityLabel}}</div>
            <div>{{{doc.priceLabel}}}</div>
        </li>
        {{/each}}
    </ol>

</section>
<div class="journal-page-content edit-mode scrollable">

  {{!-- Image Wrapper --}}
  <div class="image-wrapper">
    {{!-- Image Preview --}}
    <figure class="image-preview">
        {{#if src}}<img src="{{ src }}" alt="{{ name }}">{{/if}}
        {{#if caption}}<figcaption>{{ caption }}</figcaption>{{/if}}
    </figure>

    <div>
      {{!-- Image Source --}}
      {{formGroup fields.src value=source.src input=srcInput}}

      {{!-- Caption --}}
      {{formGroup fields.image.fields.caption value=source.image.caption}}
    </div>
  </div>

  {{!-- Editor --}}
  <prose-mirror name="text.content" class="journal-page-content" value="{{ text.content }}" data-document-uuid="{{ uuid }}" collaborate></prose-mirror>
  
  {{!-- Benefits Section --}}
  <section class="benefits-section weirdwizard">

    <h5>{{localize "WW.Tradition.Talents"}}</h5>

    {{!-- Talents --}}
    <div class="benefit-block">
      
      <ol class="described-list items-area talents">
        
        {{!-- Populate Spells --}}
        {{#each talents as |item id|}}
          {{> "systems/weirdwizard/templates/journal/parts/item-reference.hbs" item=item }}
        {{else}}{{{@root.itemsAreaHint}}}
        {{/each}}

      </ol>

    </div>
  
    {{!-- Spells --}}
    {{#each spells as |tier tierKey|}}
    <h2>
      {{#if (eq tierKey 'master')}}{{localize "WW.Spells.Master"}}
      {{else if (eq tierKey 'expert')}}{{localize "WW.Spells.Expert"}}
      {{else}}{{localize "WW.Spells.Novice"}}
      {{/if}}
    </h2>

    <div class="benefit-block">
      
      <ol class="described-list items-area spells {{tierKey}}">
        
        {{!-- Populate Spells --}}
        {{#each tier as |item id|}}
          {{> "systems/weirdwizard/templates/journal/parts/item-reference.hbs" item=item }}
        {{else}}{{{../itemsAreaHint}}}
        {{/each}}

      </ol>

    </div>
    {{/each}}

  </section>

</div>
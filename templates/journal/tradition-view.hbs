<div>

  <section class="header-section weirdwizard">

    {{!-- Right Banner --}}
    <header class="sheet-banner-wrapper">
      <hr class="spear" />
    
      <div class="sheet-banner">
        {{!-- Image --}}
        <img class="banner-img" src="{{ document.src }}" data-edit="src" data-tooltip="WW.System.EditImage" />
      </div>
    
    </header>

    {{#if title.show}}
    {{> "systems/weirdwizard/templates/journal/parts/journal-page-header.hbs" this=this }}
    {{/if}}

    {{!-- Page Content (Editor/Description) --}}
    <section class="journal-page-content">
      {{{editor.content}}}
    </section>

  </section>

  {{!-- Page Content --}}
  <section class="content-section weirdwizard">

    {{!-- Talents --}}
    {{#if talents.length}}
    <h5>{{localize "WW.Tradition.Talents"}}</h5>
    
    <ol class="described-list items-area talents">
    
      {{!-- Populate Talents --}}
      {{#each talents as |item id|}}
      <li class="item-reference item {{#if item.missing}}missing{{/if}} {{#if @root.singlePage}}draggable{{/if}}" data-item-uuid="{{item.uuid}}">
        <label><img src="{{item.img}}"> {{item.name}}{{#if item.system.magical}} ({{localize "WW.Talent.Magical"}}){{/if}}:</label>
    
        <span>{{{item.system.descriptionEnriched}}}</span>
      </li>
      {{/each}}
    
    </ol>
    {{/if}}
  
    {{!-- Spells --}}
    {{#each spells as |tier tierKey|}}
    {{#if tier.length}}
    <h2>
      {{#if (eq tierKey 'master')}}{{localize "WW.Spells.Master"}}
      {{else if (eq tierKey 'expert')}}{{localize "WW.Spells.Expert"}}
      {{else}}{{localize "WW.Spells.Novice"}}
      {{/if}}
    </h2>
    
    <ol class="formatted-spell-list items-area spells {{tierKey}}">
    
      {{!-- Populate Spells --}}
      {{#each tier as |item id|}}
      <li class="item-reference item {{#if item.missing}}missing{{/if}} {{#if @root.singlePage}}draggable{{/if}}" data-item-uuid="{{item.uuid}}">
        <div class="spell-title">
          <h3>{{ item.name }}</h3>
          <img src="{{ item.img }}" />
        </div>
    
        {{!-- Castings --}}
        <div class="inline-second">
          <label>{{localize "WW.Spell.Castings"}}:</label>
    
          {{{ system.castingsLabelEnriched }}}
        </div>
    
        {{!-- Target --}}
        <div class="inline-second">
          <label class="resource-label">{{localize "WW.Spell.Target"}}:</label>
    
          {{{ system.targetEnriched }}}
        </div>
    
        {{!-- Duration --}}
        <div class="inline-second">
          <label class="resource-label">{{localize "WW.Spell.Duration"}}:</label>
    
          {{{ system.durationEnriched }}}
        </div>
    
        <div>{{{ system.descriptionEnriched }}}</div>
    
      </li>
      {{/each}}
    
    </ol>
    {{/if}}
    {{/each}}

  </section>

</div>